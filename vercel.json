{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {"api/**/*.js": {"maxDuration": 60}},
  "crons": [
    {"path": "/api/sync?scheduled=morning", "schedule": "0 11 * * *"},
    {"path": "/api/sync?scheduled=evening", "schedule": "0 23 * * *"}
  ],
  "rewrites": [{"source": "/((?!api/).*)", "destination": "/public/$1"}]
}
