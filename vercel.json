{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {"src": "api/app.js", "use": "@vercel/node"},
    {"src": "api/oauth.js", "use": "@vercel/node"},
    {"src": "api/sync.js", "use": "@vercel/node"},
    {"src": "public/**", "use": "@vercel/static"}
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}
      ]
    },
    {
      "source": "/board-now.html",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}
      ]
    },
    {
      "source": "/board-live-54.js",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}
      ]
    },
    {
      "source": "/retired-board-data.js",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"},
        {"key": "Service-Worker-Allowed", "value": "/"}
      ]
    },
    {
      "source": "/boot-repair.js",
      "headers": [
        {"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}
      ]
    }
  ],
  "rewrites": [
    {"source": "/board-live.js", "destination": "/public/retired-board-data.js"},
    {"source": "/board-current-:version.js", "destination": "/public/retired-board-data.js"},
    {"source": "/board-correction-:version.js", "destination": "/public/retired-board-data.js"},
    {"source": "/board-holds-:version.js", "destination": "/public/retired-board-data.js"},
    {"source": "/api/login", "destination": "/api/app.js?route=login"},
    {"source": "/api/logout", "destination": "/api/app.js?route=logout"},
    {"source": "/api/board", "destination": "/api/app.js?route=board"},
    {"source": "/api/data", "destination": "/api/app.js?route=data"},
    {"source": "/api/connections", "destination": "/api/app.js?route=connections"},
    {"source": "/api/setup", "destination": "/api/app.js?route=setup"},
    {"source": "/api/records", "destination": "/api/app.js?route=records"},
    {"source": "/api/state", "destination": "/api/app.js?route=state"},
    {"source": "/api/health", "destination": "/api/app.js?route=health"},
    {"source": "/api/sync", "destination": "/api/sync.js"},
    {"source": "/api/oauth/google/start", "destination": "/api/oauth.js?provider=google&action=start"},
    {"source": "/api/oauth/google/callback", "destination": "/api/oauth.js?provider=google&action=callback"},
    {"source": "/api/oauth/quickbooks/start", "destination": "/api/oauth.js?provider=quickbooks&action=start"},
    {"source": "/api/oauth/quickbooks/callback", "destination": "/api/oauth.js?provider=quickbooks&action=callback"},
    {"source": "/", "destination": "/public/board-now.html"},
    {"source": "/((?!api/).*)", "destination": "/public/$1"}
  ]
}
